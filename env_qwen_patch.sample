# Tambahan env untuk tahap A-C
# Aktifkan semantic verifier berbasis Qwen API.
RAG_VERIFICATION_AUDIT_ENABLED=true

# Default OFF agar generator utama tetap baseline lama.
RAG_QWEN_JUDGE_ENABLED=false
RAG_QWEN_JUDGE_BASE_URL=http://127.0.0.1:8080/v1
RAG_QWEN_JUDGE_MODEL=qwen2.5:4b-instruct
RAG_QWEN_JUDGE_API_KEY=local
RAG_QWEN_JUDGE_TEMPERATURE=0.0
RAG_QWEN_JUDGE_MAX_TOKENS=600
RAG_QWEN_JUDGE_CONFIDENCE_THRESHOLD=0.80

# Contoh jika Qwen judge ingin diaktifkan:
# RAG_QWEN_JUDGE_ENABLED=true
# RAG_QWEN_JUDGE_BASE_URL=https://<endpoint-qwen-compatible>/v1
# RAG_QWEN_JUDGE_MODEL=<nama-model-qwen-4b>
# RAG_QWEN_JUDGE_API_KEY=<api-key>
